class Usuario:
    """Modela un usuario del sistema."""
 
    _siguiente_id = 1
 
    def __init__(self, nombre, apellido, tipo_usuario,
                 email, fecha_registro=None, activo=True, id_usuario=None):
        if id_usuario is not None:
            self.__id_usuario = id_usuario
        else:
            self.__id_usuario = Usuario._siguiente_id
            Usuario._siguiente_id += 1
        self.__nombre         = nombre
        self.__apellido       = apellido
        self.__tipo_usuario   = tipo_usuario   # estudiante | docente | administrativo
        self.__email          = email
        self.__fecha_registro = fecha_registro or date.today()
        self.__activo         = activo
        self.__historial      = ListaEnlazadaPrestamos()
 
    # Getters
    def get_id_usuario(self):    return self.__id_usuario
    def get_nombre(self):        return self.__nombre
    def get_apellido(self):      return self.__apellido
    def get_tipo_usuario(self):  return self.__tipo_usuario
    def get_email(self):         return self.__email
    def get_fecha_registro(self):return self.__fecha_registro
    def get_activo(self):        return self.__activo
    def get_historial(self):     return self.__historial
 
    def agregar_prestamo(self, prestamo: Prestamo):
        self.__historial.agregar(prestamo)
 
    def prestamos_activos(self):
        return self.__historial.listar_activos()
 
    def mostrar_info(self):
        print(f"  [{self.__id_usuario}] {self.__nombre} {self.__apellido}")
        print(f"       Tipo    : {self.__tipo_usuario}  |  Email: {self.__email}")
        print(f"       Registro: {self.__fecha_registro}  |  Activo: {'Sí' if self.__activo else 'No'}")
 
    def __str__(self):
        return f"Usuario({self.__id_usuario}, '{self.__nombre} {self.__apellido}')"
 
 
