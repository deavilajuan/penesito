# 2. ÁRBOL BINARIO DE BÚSQUEDA (ABB) — catálogo de libros
# ============================================================
 
class NodoABB:
    def __init__(self, libro: Libro):
        self.libro = libro
        self.izq   = None
        self.der   = None
 
 
class ArbolBinarioBusqueda:
    """ABB ordenado por título (alfabético)."""
 
    def __init__(self):
        self.__raiz  = None
        self.__total = 0
 
    def get_total(self): return self.__total
 
    def insertar(self, libro: Libro):
        self.__raiz   = self.__insertar_rec(self.__raiz, libro)
        self.__total += 1
 
    def __insertar_rec(self, nodo, libro):
        if nodo is None:
            return NodoABB(libro)
        clave = libro.get_titulo().lower()
        cnodo = nodo.libro.get_titulo().lower()
        if clave < cnodo:
            nodo.izq = self.__insertar_rec(nodo.izq, libro)
        elif clave > cnodo:
            nodo.der = self.__insertar_rec(nodo.der, libro)
        else:
            nodo.libro = libro  # actualizar duplicado
        return nodo
 
    def buscar_titulo(self, titulo: str):
        return self.__buscar_rec(self.__raiz, titulo.lower())
 
    def __buscar_rec(self, nodo, tl):
        if nodo is None:
            return None
        clave = nodo.libro.get_titulo().lower()
        if tl == clave:  return nodo.libro
        if tl <  clave:  return self.__buscar_rec(nodo.izq, tl)
        return self.__buscar_rec(nodo.der, tl)
 
    def buscar_titulo_parcial(self, fragmento: str) -> list:
        res = []
        self.__parcial_rec(self.__raiz, fragmento.lower(), res)
        return res
 
    def __parcial_rec(self, nodo, frag, res):
        if nodo is None: return
        self.__parcial_rec(nodo.izq, frag, res)
        if frag in nodo.libro.get_titulo().lower():
            res.append(nodo.libro)
        self.__parcial_rec(nodo.der, frag, res)
 
    def buscar_autor(self, autor: str) -> list:
        res = []
        self.__campo_rec(self.__raiz, autor.lower(),
                         lambda l: l.get_autor().lower(), res)
        return res
 
    def buscar_categoria(self, categoria: str) -> list:
        res = []
        self.__campo_rec(self.__raiz, categoria.lower(),
                         lambda l: l.get_categoria().lower(), res)
        return res
 
    def __campo_rec(self, nodo, valor, extractor, res):
        if nodo is None: return
        self.__campo_rec(nodo.izq, valor, extractor, res)
        if valor in extractor(nodo.libro):
            res.append(nodo.libro)
        self.__campo_rec(nodo.der, valor, extractor, res)
 
    def eliminar(self, titulo: str):
        self.__raiz, ok = self.__eliminar_rec(self.__raiz, titulo.lower())
        if ok: self.__total -= 1
        return ok
 
    def __eliminar_rec(self, nodo, tl):
        if nodo is None: return nodo, False
        clave = nodo.libro.get_titulo().lower()
        if tl < clave:
            nodo.izq, ok = self.__eliminar_rec(nodo.izq, tl)
            return nodo, ok
        if tl > clave:
            nodo.der, ok = self.__eliminar_rec(nodo.der, tl)
            return nodo, ok
        if nodo.izq is None: return nodo.der, True
        if nodo.der is None: return nodo.izq, True
        sucesor    = self.__minimo(nodo.der)
        nodo.libro = sucesor.libro
        nodo.der, _ = self.__eliminar_rec(nodo.der, sucesor.libro.get_titulo().lower())
        return nodo, True
 
    def __minimo(self, nodo):
        while nodo.izq: nodo = nodo.izq
        return nodo
 
    def in_orden(self) -> list:
        libros = []
        self.__in_orden_rec(self.__raiz, libros)
        return libros
 
    def __in_orden_rec(self, nodo, libros):
        if nodo is None: return
        self.__in_orden_rec(nodo.izq, libros)
        libros.append(nodo.libro)
        self.__in_orden_rec(nodo.der, libros)
 
 
