class Biblioteca:
    """
    Contenedor principal del sistema.
    Coordina el ABB de libros, la lista de usuarios y los préstamos.
    Todo en memoria: los datos de ejemplo se cargan al iniciar.
    """
 
    def __init__(self):
        self.__abb_libros     = ArbolBinarioBusqueda()
        self.__lista_usuarios = ListaEnlazadaUsuarios()
        self.__prestamos      = []
 
    # ---- CARGA INICIAL ----
 
    def cargar_datos_ejemplo(self):
        print("\n── Cargando catálogo y usuarios de ejemplo ──")
        for datos in LIBROS_EJEMPLO:
            libro = Libro(*datos)
            self.__abb_libros.insertar(libro)
        print(f"  → {self.__abb_libros.get_total()} libro(s) cargado(s) en el ABB.")
 
        for datos in USUARIOS_EJEMPLO:
            usuario = Usuario(*datos)
            self.__lista_usuarios.agregar(usuario)
        print(f"  → {self.__lista_usuarios.get_tamaño()} usuario(s) cargado(s).")
        print("── Carga completada ──\n")
 
    # ---- GESTIÓN DE LIBROS ----
 
    def agregar_libro(self, titulo, autor, categoria,
                      anio_publicacion, isbn=None):
        libro = Libro(titulo, autor, categoria, anio_publicacion, isbn)
        self.__abb_libros.insertar(libro)
        print(f"✔ Libro '{titulo}' agregado con ID {libro.get_id_libro()}.")
        return libro
 
    def buscar_libro_titulo(self, titulo: str):
        return self.__abb_libros.buscar_titulo_parcial(titulo)
 
    def buscar_libro_autor(self, autor: str):
        return self.__abb_libros.buscar_autor(autor)
 
    def buscar_libro_categoria(self, categoria: str):
        return self.__abb_libros.buscar_categoria(categoria)
 
    def buscar_libro_id(self, id_libro: int):
        for l in self.__abb_libros.in_orden():
            if l.get_id_libro() == id_libro:
                return l
        return None
 
    def listar_catalogo(self):
        return self.__abb_libros.in_orden()
 
    def eliminar_libro(self, titulo: str) -> bool:
        libro = self.__abb_libros.buscar_titulo(titulo)
        if not libro:
            print(f"✘ Libro '{titulo}' no encontrado.")
            return False
        for p in self.__prestamos:
            if (p.get_libro().get_id_libro() == libro.get_id_libro()
                    and p.get_estado() == 'activo'):
                print("✘ El libro tiene préstamos activos. No se puede eliminar.")
                return False
        self.__abb_libros.eliminar(titulo)
        print(f"✔ Libro '{titulo}' eliminado.")
        return True
 
    # ---- GESTIÓN DE USUARIOS ----
 
    def registrar_usuario(self, nombre, apellido, tipo_usuario, email):
        if self.__lista_usuarios.buscar_por_email(email):
            print(f"✘ Ya existe un usuario con el email '{email}'.")
            return None
        usuario = Usuario(nombre, apellido, tipo_usuario, email)
        self.__lista_usuarios.agregar(usuario)
        print(f"✔ Usuario '{nombre} {apellido}' registrado con ID {usuario.get_id_usuario()}.")
        return usuario
 
    def buscar_usuario_id(self, id_usuario: int):
        return self.__lista_usuarios.buscar_por_id(id_usuario)
 
    def listar_usuarios(self):
        return self.__lista_usuarios.listar_todos()
 
    # ---- GESTIÓN DE PRÉSTAMOS ----
 
    def registrar_prestamo(self, id_libro: int, id_usuario: int,
                           dias_prestamo: int = 14):
        libro   = self.buscar_libro_id(id_libro)
        usuario = self.__lista_usuarios.buscar_por_id(id_usuario)
 
        if not libro:
            print("✘ Libro no encontrado.")
            return None
        if not usuario:
            print("✘ Usuario no encontrado.")
            return None
        if not libro.get_estado_disponible():
            print(f"✘ El libro '{libro.get_titulo()}' no está disponible.")
            return None
 
        hoy     = date.today()
        vence   = hoy + timedelta(days=dias_prestamo)
        prestamo = Prestamo(libro, usuario, hoy, vence)
 
        libro.set_estado_disponible(False)
        usuario.agregar_prestamo(prestamo)
        self.__prestamos.append(prestamo)
        print(f"✔ Préstamo registrado (ID {prestamo.get_id_prestamo()}). Vence: {vence}")
        return prestamo
 
    def registrar_devolucion(self, id_prestamo: int) -> bool:
        prestamo = None
        for p in self.__prestamos:
            if p.get_id_prestamo() == id_prestamo:
                prestamo = p
                break
 
        if not prestamo:
            print("✘ Préstamo no encontrado.")
            return False
        if prestamo.get_estado() != 'activo':
            print("✘ El préstamo ya fue completado o está vencido.")
            return False
 
        hoy = date.today()
        prestamo.set_estado('completado')
        prestamo.set_fecha_devolucion_real(hoy)
        prestamo.get_libro().set_estado_disponible(True)
        print(f"✔ Devolución registrada. Libro '{prestamo.get_libro().get_titulo()}' disponible.")
        return True
 
    def historial_usuario(self, id_usuario: int):
        usuario = self.__lista_usuarios.buscar_por_id(id_usuario)
        if not usuario:
            print("✘ Usuario no encontrado.")
            return []
        return usuario.get_historial().listar_todos()
 
    def prestamos_activos(self):
        return [p for p in self.__prestamos if p.get_estado() == 'activo']
 
 
