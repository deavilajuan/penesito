class Libro:
    """Representa un libro en el catálogo."""
 
    _siguiente_id = 1  # Contador global de IDs
 
    def __init__(self, titulo, autor, categoria,
                 anio_publicacion, isbn=None, estado_disponible=True, id_libro=None):
        if id_libro is not None:
            self.__id_libro = id_libro
        else:
            self.__id_libro = Libro._siguiente_id
            Libro._siguiente_id += 1
        self.__titulo            = titulo
        self.__autor             = autor
        self.__categoria         = categoria
        self.__anio_publicacion  = anio_publicacion
        self.__isbn              = isbn
        self.__estado_disponible = estado_disponible
 
    # Getters
    def get_id_libro(self):          return self.__id_libro
    def get_titulo(self):            return self.__titulo
    def get_autor(self):             return self.__autor
    def get_categoria(self):         return self.__categoria
    def get_anio_publicacion(self):  return self.__anio_publicacion
    def get_isbn(self):              return self.__isbn
    def get_estado_disponible(self): return self.__estado_disponible
 
    # Setters
    def set_estado_disponible(self, v): self.__estado_disponible = v
 
    def mostrar_info(self):
        estado = "Disponible" if self.__estado_disponible else "Prestado"
        print(f"  [{self.__id_libro}] {self.__titulo}")
        print(f"       Autor    : {self.__autor}")
        print(f"       Categoría: {self.__categoria}  |  Año: {self.__anio_publicacion}")
        print(f"       ISBN     : {self.__isbn or 'N/A'}  |  Estado: {estado}")
 
    def __str__(self):
        return f"Libro({self.__id_libro}, '{self.__titulo}', '{self.__autor}')"
 
 
