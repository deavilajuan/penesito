class NodoPrestamo:
    """Nodo de la lista enlazada de préstamos."""
 
    def __init__(self, prestamo):
        self.prestamo  = prestamo
        self.siguiente = None
 
 
class Prestamo:
    """Registra la relación entre un usuario y un libro."""
 
    _siguiente_id = 1
 
    def __init__(self, libro, usuario, fecha_prestamo,
                 fecha_devolucion_esperada,
                 fecha_devolucion_real=None, estado='activo', id_prestamo=None):
        if id_prestamo is not None:
            self.__id_prestamo = id_prestamo
        else:
            self.__id_prestamo = Prestamo._siguiente_id
            Prestamo._siguiente_id += 1
        self.__libro                     = libro
        self.__usuario                   = usuario
        self.__fecha_prestamo            = fecha_prestamo
        self.__fecha_devolucion_esperada = fecha_devolucion_esperada
        self.__fecha_devolucion_real     = fecha_devolucion_real
        self.__estado                    = estado  # activo | completado | vencido
 
    # Getters
    def get_id_prestamo(self):               return self.__id_prestamo
    def get_libro(self):                     return self.__libro
    def get_usuario(self):                   return self.__usuario
    def get_fecha_prestamo(self):            return self.__fecha_prestamo
    def get_fecha_devolucion_esperada(self): return self.__fecha_devolucion_esperada
    def get_fecha_devolucion_real(self):     return self.__fecha_devolucion_real
    def get_estado(self):                    return self.__estado
 
    # Setters
    def set_estado(self, v):                 self.__estado = v
    def set_fecha_devolucion_real(self, v):  self.__fecha_devolucion_real = v
 
    def mostrar_info(self):
        print(f"  Préstamo #{self.__id_prestamo}")
        print(f"    Libro   : {self.__libro.get_titulo()}")
        print(f"    Usuario : {self.__usuario.get_nombre()} {self.__usuario.get_apellido()}")
        print(f"    Desde   : {self.__fecha_prestamo}  →  Vence: {self.__fecha_devolucion_esperada}")
        if self.__fecha_devolucion_real:
            print(f"    Devuelto: {self.__fecha_devolucion_real}")
        print(f"    Estado  : {self.__estado.upper()}")
 
 
