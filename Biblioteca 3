def separador(titulo=""):
    print("\n" + "═" * 55)
    if titulo:
        print(f"  {titulo}")
        print("═" * 55)
 
def mostrar_libros(libros):
    if not libros:
        print("  (Sin resultados)")
        return
    for l in libros:
        l.mostrar_info()
        print()
 
def menu_libros(bib: Biblioteca):
    while True:
        separador("GESTIÓN DE LIBROS")
        print("  1. Ver catálogo completo")
        print("  2. Buscar por título")
        print("  3. Buscar por autor")
        print("  4. Buscar por categoría")
        print("  5. Buscar por ID")
        print("  6. Agregar libro manualmente")
        print("  7. Eliminar libro")
        print("  0. Volver")
        op = input("\n  Opción: ").strip()
 
        if op == '1':
            separador("CATÁLOGO COMPLETO")
            mostrar_libros(bib.listar_catalogo())
 
        elif op == '2':
            t = input("  Título (o fragmento): ").strip()
            separador(f"Resultados para '{t}'")
            mostrar_libros(bib.buscar_libro_titulo(t))
 
        elif op == '3':
            a = input("  Autor (o fragmento): ").strip()
            separador(f"Resultados para '{a}'")
            mostrar_libros(bib.buscar_libro_autor(a))
 
        elif op == '4':
            c = input("  Categoría: ").strip()
            separador(f"Categoría '{c}'")
            mostrar_libros(bib.buscar_libro_categoria(c))
 
        elif op == '5':
            try:
                bid = int(input("  ID del libro: ").strip())
                libro = bib.buscar_libro_id(bid)
                if libro:
                    print()
                    libro.mostrar_info()
                else:
                    print("  (Libro no encontrado)")
            except ValueError:
                print("  ID inválido.")
 
        elif op == '6':
            separador("AGREGAR LIBRO")
            titulo = input("  Título         : ").strip()
            autor  = input("  Autor          : ").strip()
            cat    = input("  Categoría      : ").strip()
            try:
                anio = int(input("  Año publicación: ").strip())
            except ValueError:
                print("  Año inválido.")
                continue
            isbn = input("  ISBN (Enter para omitir): ").strip() or None
            bib.agregar_libro(titulo, autor, cat, anio, isbn)
 
        elif op == '7':
            titulo = input("  Título exacto del libro a eliminar: ").strip()
            bib.eliminar_libro(titulo)
 
        elif op == '0':
            break
        else:
            print("  Opción inválida.")
 
